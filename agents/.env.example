# Asset402 Agent Environment Configuration
# Copy to .env and fill in your values before running

# ── Casper Network ──────────────────────────────────────────────────────────
CASPER_NETWORK=casper-test
CASPER_NODE_URL=https://node.testnet.casper.network/rpc

# ── Agent Wallet ──────────────────────────────────────────────────────────────
# Path to a Casper secret-key PEM file (Secp256K1 or Ed25519 — loadAgentKey()
# in src/lib/casper-key.ts tries both). Generate a wallet via `casper-client
# keygen` or the Casper Wallet browser extension's key export.
AGENT_PRIVATE_KEY_PATH=/absolute/path/to/secret_key.pem
AGENT_PUBLIC_KEY_HEX=your_64_char_hex_public_key_here
AGENT_WALLET_ADDRESS=your_casper_account_hash_hex_here

# ── AI Vision (Anthropic Claude) ────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── IPFS Photo Storage (optional — falls back to public gateway if unset) ──
IPFS_API_KEY=your_pinata_jwt_here

# ── x402 Configuration ──────────────────────────────────────────────────────
X402_MAX_PAYMENT_MOTES=1000000   # 0.001 CSPR ceiling per call

# ── MCP Server URLs ─────────────────────────────────────────────────────────
CASPER_MCP_URL=https://mcp.cspr.cloud
CSPRTRADE_MCP_URL=https://mcp.cspr.trade

# ── AI Vision Model ─────────────────────────────────────────────────────────
MOONDREAM_API_URL=http://localhost:8080/v1/classify   # or remote Moondream2 endpoint

# ── x402 Mock Oracle ────────────────────────────────────────────────────────
# ORACLE_WALLET_ADDRESS MUST be a real public-key hex (what the 402 challenge
# sends as the transfer target) — NOT an account hash. Native CSPR transfers
# require the actual public key; an account hash (blake2b of the public key)
# cannot be used as a transfer target and will be rejected.
ORACLE_URL=http://localhost:4402/v1/price
ORACLE_PORT=4402
ORACLE_PRIVATE_KEY_HEX=oracle_64_char_hex_private_key
ORACLE_PUBLIC_KEY_HEX=oracle_64_char_hex_public_key
ORACLE_WALLET_ADDRESS=oracle_public_key_hex
ORACLE_PAYMENT_AMOUNT=500000   # 0.0005 CSPR per call

# ── API Gateway ─────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3000

# ── Contract Addresses (deploy to testnet first) ─────────────────────────────
ASSET_REGISTRY_ADDR=contract_hash_after_deploy
CARBON_CREDIT_ADDR=contract_hash_after_deploy
FRACTIONAL_REGISTRY_ADDR=contract_hash_after_deploy
LENDING_POOL_ADDR=contract_hash_after_deploy
RENTAL_ESCROW_ADDR=contract_hash_after_deploy
# Must be a public-key hex (same format as AGENT_PUBLIC_KEY_HEX), not an
# account hash — see the ORACLE_WALLET_ADDRESS note above for why.
PROTOCOL_VAULT=your_fee_vault_public_key_hex

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
